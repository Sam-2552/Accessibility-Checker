# WebAPT Environment Configuration
# Copy to .env and fill in your values

# Model provider: "litellm" or "gemini"
MODEL_PROVIDER=litellm

# LiteLLM proxy settings
LITELLM_V_KEY=
LITELLM_BASE_URL=https://llmproxy.securin.io/
LITELLM_MODEL_ID=azure/gpt-4.1

# Gemini settings (alternative provider)
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.0-flash

# Project settings
WEBAPT_PROJECT=web_analysis
WEBAPT_OUTPUT_ROOT=./outputs
WEBAPT_HEADLESS=true

# Langfuse observability (local: http://localhost:3000)
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
